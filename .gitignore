# dependencies
node_modules/

# build output
out/
dist/
release/
*.tsbuildinfo

# electron-vite / vite caches
.vite/
.cache/

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# secrets / local config (API keys live in %APPDATA%\COSMOS, never in-repo,
# but guard against any local env files)
.env
.env.*
!.env.example

# editor / OS
.DS_Store
Thumbs.db
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# scratch / temp
scratch-*
*.local

# Bundled Piper runtime + voice models (~270 MB) — shipped via
# electron-builder extraResources so the installer always contains Piper.
# Kept out of git (large, third-party). Restored from upstream by
# `npm run setup:piper`, which also runs automatically before `npm run dist`
# (predist hook). See scripts/fetch-piper.mjs.
resources/piper/

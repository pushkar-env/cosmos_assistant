# dependencies
node_modules/

# build output
out/
dist/
release/
*.tsbuildinfo

# electron-vite / vite caches
.vite/
.cache/

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# secrets / local config (API keys live in %APPDATA%\COSMOS, never in-repo,
# but guard against any local env files)
.env
.env.*
!.env.example

# editor / OS
.DS_Store
Thumbs.db
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# scratch / temp
scratch-*
*.local

# Bundled Piper runtime + voice (~89 MB) — shipped via electron-builder
# extraResources so the installer always contains Piper. Kept out of git
# to avoid bloating the repo; regenerate locally before `npm run dist` by
# copying piper.exe + its DLLs + espeak-ng-data and one .onnx voice into
# resources/piper/ (see docs). CI/other machines must restore it too.
resources/piper/
